# Copy this file to `.env` in the project root before running the app.
#
# The app talks ONLY to your own backend proxy (see ./server) — it NEVER holds
# the DeepSeek API key. That secret lives on the server. Deploy the proxy, then
# point AI_PROXY_URL at it.

# Base URL of your deployed AI proxy.
#   Android emulator -> host machine:  http://10.0.2.2:8080
#   iOS simulator    -> host machine:  http://127.0.0.1:8080
#   Production        -> https://your-proxy.example.com
AI_PROXY_URL=

# Shared client key the proxy expects in the `x-app-key` header.
# Must match one of APP_API_KEYS in the server's .env.
# NOTE: anything shipped in the app can be extracted, so this only stops casual
# abuse of your proxy — it is not a substitute for real user auth.
AI_APP_KEY=
