# ---- NoteHeaven AI proxy configuration ----
# Copy to `.env` for local development. In production, set these as real
# environment variables in your host (Render / Railway / Fly / Cloud Run / ...).

# REQUIRED — your DeepSeek secret. This is the ONLY place it should ever live.
DEEPSEEK_API_KEY=

# Comma-separated client keys the app must send in the `x-app-key` header.
# REQUIRED in production — the server refuses to start without it, otherwise the
# proxy is an open relay that bills your DeepSeek account.
# Generate one with:  openssl rand -hex 32
APP_API_KEYS=

# ---- Optional (defaults shown) ----
PORT=8080
NODE_ENV=development

# DeepSeek upstream
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
UPSTREAM_TIMEOUT_MS=30000

# Abuse / cost controls
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
MAX_INPUT_CHARS=8000
BODY_LIMIT=32kb

# CORS — leave empty for native mobile clients (they send no Origin). Set to a
# comma-separated list of origins (or *) only if a web app also calls the proxy.
CORS_ORIGINS=

# Proxy hops to trust for the real client IP (rate limiting). 1 = one LB in front.
TRUST_PROXY=1
